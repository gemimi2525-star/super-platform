{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "declaration": true,
        "declarationMap": true,
        "outDir": "./dist",
        "composite": false,
        "paths": {
            "@platform/core": [
                "../../packages/core/src"
            ],
            "@platform/firebase": [
                "../../packages/firebase/src"
            ],
            "@platform/types": [
                "../../packages/types/src"
            ],
            "@platform/ui": [
                "../../packages/ui/src"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}